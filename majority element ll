class Solution:
    def majorityElement(self, nums: List[int]) -> List[int]:
        # hashing
        occ = defaultdict(int)
        for i in range(len(nums)):
            occ[nums[i]]+=1
        
        res = []
        threshold = len(nums)//3
        for key,value in occ.items():
            if value > threshold:
                res.append(key)
        
        return res
