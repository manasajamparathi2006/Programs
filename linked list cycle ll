# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, x):
#         self.val = x
#         self.next = None

class Solution:
    def detectCycle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        ptr=head
        l=[]
        while ptr!=None:
            if ptr not in l :
                l.append(ptr)
                ptr=ptr.next
            else :
                return ptr

        return None

        
